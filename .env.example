# ─────────────────────────────────────────────
# Shared / root
# ─────────────────────────────────────────────
NODE_ENV=production

# ─────────────────────────────────────────────
# PostgreSQL (local Docker Compose only)
# Production: replace with your RDS endpoint
# ─────────────────────────────────────────────
POSTGRES_USER=collab
POSTGRES_PASSWORD=collab_pass
POSTGRES_DB=collab_db

# ─────────────────────────────────────────────
# Backend (compose overrides PORT=3000 for frontend only)
# ─────────────────────────────────────────────
PORT=5001

# Local:  postgresql://collab:collab_pass@postgres:5432/collab_db
# AWS:    postgresql://<user>:<pass>@<rds-endpoint>:5432/<dbname>
DATABASE_URL=postgresql://collab:collab_pass@postgres:5432/collab_db

JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string

OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────────
# Local:  http://localhost:5001/api
# AWS:    http://<EC2-public-ip>:5001/api
NEXT_PUBLIC_API_URL=http://localhost:5001/api
